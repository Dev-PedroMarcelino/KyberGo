# ============================================================
# KyberGo — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores.
# Sem credenciais, o sistema roda em MODO DEMONSTRAÇÃO (dados mock).
# ============================================================

# --- Supabase (banco de dados, auth e storage) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Provedor de WhatsApp (camada adaptadora genérica) ---
# Valores possíveis: zapi | uazapi | azapi | custom
WHATSAPP_PROVIDER=
WHATSAPP_API_BASE_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_WEBHOOK_SECRET=

# --- Provedor de IA ---
AI_PROVIDER=anthropic
AI_API_KEY=
AI_MODEL=

# --- Provedor de pagamento/assinaturas ---
# Valores possíveis: stripe | pagarme | asaas | custom
BILLING_PROVIDER=
BILLING_API_KEY=
BILLING_WEBHOOK_SECRET=

# --- Geração de PDF ---
PDF_STORAGE_BUCKET=kybergo-pdfs

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
